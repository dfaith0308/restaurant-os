# 식당OS 로컬 환경 변수 예시
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_SCHEMA=public

# 토스페이먼츠 (키 입력 시 카드결제 활성화)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_여기에키입력
TOSS_SECRET_KEY=test_sk_여기에키입력

# 결제 성공 콜백용 앱 URL (Vercel 배포 시)
NEXT_PUBLIC_APP_URL=https://restaurant.siksiki.com
